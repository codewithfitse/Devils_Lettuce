NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/devils_lettuce
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

FRONTEND_URL=http://localhost:5173

# Telebirr payment account shown when orders are accepted
TELEBIRR_ACCOUNT=0982863015

# Background OCR on payment screenshots (Tesseract)
PAYMENT_VERIFY_ENABLED=true
TESSERACT_LANG=eng

# Comma-separated extra origins (Vercel previews, custom domains)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# Telegram — only ONE process can poll a bot token (Telegram API rule)
#
# Local (.env):        ENABLE_TELEGRAM_BOT=false  → bot runs on Render only
# Render (dashboard):  NODE_ENV=production        → bot on by default
#                      ENABLE_TELEGRAM_BOT=false  → only if you want to disable it
#
# To test the bot locally: pause Render, then ENABLE_TELEGRAM_BOT=true
# Or use a separate test bot: TELEGRAM_BOT_TOKEN_LOCAL=...
ENABLE_TELEGRAM_BOT=false

# Render keep-alive (optional — RENDER_EXTERNAL_URL is auto-set on Render)
# BACKEND_URL=https://your-app.onrender.com
