NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/devils_lettuce
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

FRONTEND_URL=http://localhost:5173

# Comma-separated extra origins (Vercel previews, custom domains)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# Telegram — only one process can poll the same bot token at a time
# Option A: use production bot locally (pause Render first)
ENABLE_TELEGRAM_BOT=true
# Option B: separate dev bot — no conflict with Render (recommended)
# TELEGRAM_BOT_TOKEN_LOCAL=your_dev_bot_token_from_botfather

# Render keep-alive (optional — RENDER_EXTERNAL_URL is auto-set on Render)
# BACKEND_URL=https://your-app.onrender.com
