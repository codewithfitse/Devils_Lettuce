# Local dev — Vite proxies /api to the backend (do not set VITE_API_URL locally)
# VITE_BACKEND_URL=http://127.0.0.1:5000

# Optional override (local or Vercel). If unset, production builds use Render directly.
# VITE_API_URL=https://devils-lettuce.onrender.com/api

# --- Dev Tunnels (Cursor/VS Code: forward ports 5173 + 5000 as Public) ---
# Backend must run on YOUR machine (not Render) so Telebirr receipt fetch uses your network.
# Replace with your tunnel URLs from the Ports panel.
#
# VITE_API_URL=https://YOUR-TUNNEL-5000.inc1.devtunnels.ms/api
#
# Copy to frontend/.env.local when testing via tunnel.
